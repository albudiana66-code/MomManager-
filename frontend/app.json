{
  "expo": {
    "name": "MomManager 2026",
    "slug": "mommanager2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mommanager",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scanează bonuri pentru buget",
        "NSPhotoLibraryUsageDescription": "Selectează imagini cu bonuri"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#fdf2f8"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["android.permission.CAMERA", "android.permission.READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#fdf2f8"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Selectează imagini pentru scanare bonuri",
          "cameraPermission": "Folosește camera pentru scanare bonuri"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
